+
+        com.google.gson.JsonArray layers = new com.google.gson.JsonArray();
+        String[] suffixes = { "", "_secondary", "_overlay" };
+        for (int i = 0; i < suffixes.length; i++) {
+            if (!java.nio.file.Files.exists(texDir.resolve(owner).resolve(texName + suffixes[i] + ".png")))
