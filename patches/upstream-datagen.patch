+    // Emits a `render` block onto a material item's JSON — the ordered
+    // {texture, argb} layers upstream renders. MaterialIconType.getItemTexturePath
+    // bails server-side, so we replicate its iconset-parent-chain fallback by
+    // walking the source texture tree directly. argb is Material.getLayerARGB
+    // (upstream's exact per-layer tint; -1/0xFFFFFFFF means untinted).
+    // `category` is "item" (TagPrefixItem) or "block" (MaterialBlockItem) —
+    // upstream splits per-prefix item sprites from block sprites into two trees.
+    private static void emitRenderLayers(com.google.gson.JsonObject o,
+            com.gregtechceu.gtceu.api.data.chemical.material.Material material,
+            com.gregtechceu.gtceu.api.data.tag.TagPrefix tagPrefix,
+            net.minecraft.data.PackOutput packOutput, String category) {
+        var iconType = tagPrefix.materialIconType();
+        if (iconType == null) return;
+
+        // ingotHot's item model (ingot_hot.json) is hand-authored — it reuses
+        // the regular `ingot` textures and adds an `ingot_hot_overlay` layer
+        // (and radioactive parents dull/ingot_hot cross-iconset). The
+        // iconType-name + suffix heuristic below can't reconstruct that: it
+        // looks for a nonexistent `ingot_hot_secondary` and stops after the
+        // base layer. Read the model JSON directly for this prefix instead.
+        if (category.equals("item")
+                && tagPrefix == com.gregtechceu.gtceu.api.data.tag.TagPrefix.ingotHot) {
+            emitRenderLayersFromModel(o, material, iconType, packOutput);
+            return;
+        }
+
+        // If the material's iconSet ships an explicit per-prefix model JSON
+        // (e.g. `magnetic/rod.json` overrides layer2 to magnetic_overlay; the
+        // metallic parent provides the base + secondary), read the model JSON
+        // directly. The filename-suffix heuristic below would pin EVERY layer
+        // to the resolved owner iconset and miss the override entirely — for
+        // magnetic_iron's rod that strips the magnetic stripes back to a plain
+        // metallic rod. Apply only to `item` (block textures don't use
+        // model-JSON overrides this way).
+        if (category.equals("item")) {
+            String typeNameProbe = iconType.name();
+            java.nio.file.Path modelProbe = packOutput.getOutputFolder().getParent().getParent()
+                    .resolve("main/resources/assets/gtceu/models/item/material_sets/"
+                            + material.getMaterialIconSet().name + "/" + typeNameProbe + ".json");
+            if (java.nio.file.Files.exists(modelProbe)) {
+                emitRenderLayersFromModel(o, material, iconType, packOutput);
+                return;
+            }
+        }
+
+        String typeName = iconType.name();
+        // Texture filename ≠ icon-type name for one upstream oddity:
+        // MaterialIconType.toolHeadWireCutter → `tool_head_wire_cutter`, but the
+        // shipped sprite is `tool_head_wirecutter.png` (one word).
