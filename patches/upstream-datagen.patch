+        com.google.gson.JsonObject render = new com.google.gson.JsonObject();
+        render.addProperty("iconType", typeName);
+        render.addProperty("iconSet", iconSet.name);
+        render.add("layers", layers);
+        o.add("render", render);
+    }
+
+    // Reads a hand-authored item model JSON (item/material_sets/<set>/<type>.json)
+    // and emits its layerN textures verbatim — for prefixes like ingotHot whose
+    // model reuses other iconTypes' textures and so can't be reconstructed from
+    // the iconType-name + suffix convention emitRenderLayers assumes.
+    private static void emitRenderLayersFromModel(com.google.gson.JsonObject o,
+            com.gregtechceu.gtceu.api.data.chemical.material.Material material,
+            com.gregtechceu.gtceu.api.data.chemical.material.info.MaterialIconType iconType,
+            net.minecraft.data.PackOutput packOutput) {
+        java.nio.file.Path models = packOutput.getOutputFolder().getParent().getParent()
+                .resolve("main/resources/assets/gtceu/models");
+        var iconSet = material.getMaterialIconSet();
+        String typeName = iconType.name();
+
+        // Walk the iconset parent chain for the first set that ships the model.
+        String owner = null;
+        var cur = iconSet;
+        while (cur != null) {
+            if (java.nio.file.Files.exists(
+                    models.resolve("item/material_sets/" + cur.name + "/" + typeName + ".json"))) {
+                owner = cur.name;
+                break;
+            }
+            if (cur.isRootIconset) break;
+            cur = cur.parentIconset;
+        }
+        if (owner == null) return;
+
+        // Merge layerN textures across the model's parent chain (parent first,
+        // child overrides) — e.g. radioactive/ingot_hot parents dull/ingot_hot.
+        java.util.TreeMap<Integer, String> layerTextures = new java.util.TreeMap<>();
+        collectModelLayers(models, "item/material_sets/" + owner + "/" + typeName, layerTextures, 0);
+        if (layerTextures.isEmpty()) return;
+
+        com.google.gson.JsonArray layers = new com.google.gson.JsonArray();
+        for (var entry : layerTextures.entrySet()) {
+            com.google.gson.JsonObject layer = new com.google.gson.JsonObject();
+            layer.addProperty("texture", entry.getValue());
+            layer.addProperty("argb", material.getLayerARGB(entry.getKey()));
+            layers.add(layer);
+        }
+        com.google.gson.JsonObject render = new com.google.gson.JsonObject();
+        render.addProperty("iconType", typeName);
+        render.addProperty("iconSet", iconSet.name);
+        render.add("layers", layers);
+        o.add("render", render);
+    }
+
+    // Recursively merges `layerN` texture entries from an item model JSON and
+    // its `parent` chain. Parent layers are collected first so the child's
+    // `textures` block overrides them. `modelPath` is relative to .../models
+    // (e.g. "item/material_sets/dull/ingot_hot"), no extension.
+    private static void collectModelLayers(java.nio.file.Path models, String modelPath,
+            java.util.TreeMap<Integer, String> out, int depth) {
+        if (depth > 16) return;   // parent-chain cycle guard
+        java.nio.file.Path file = models.resolve(modelPath + ".json");
+        if (!java.nio.file.Files.exists(file)) return;
+        com.google.gson.JsonObject model;
+        try (var reader = java.nio.file.Files.newBufferedReader(file)) {
+            model = com.google.gson.JsonParser.parseReader(reader).getAsJsonObject();
+        } catch (Exception ex) {
+            return;
+        }
+        if (model.has("parent")) {
+            String parent = model.get("parent").getAsString();
+            if (parent.startsWith("gtceu:")) parent = parent.substring(6);
+            if (parent.startsWith("item/material_sets/"))
+                collectModelLayers(models, parent, out, depth + 1);
+        }
+        if (model.has("textures")) {
+            com.google.gson.JsonObject tex = model.getAsJsonObject("textures");
+            for (var e : tex.entrySet()) {
+                if (!e.getKey().startsWith("layer")) continue;
+                int idx;
+                try {
+                    idx = Integer.parseInt(e.getKey().substring(5));
+                } catch (NumberFormatException nfe) {
+                    continue;
+                }
+                String t = e.getValue().getAsString();
+                if (t.startsWith("gtceu:")) t = t.substring(6);
+                out.put(idx, t);
+            }
+        }
+    }
+
+    // Walks iconSet → parentIconset until `<iconset>/<type><suffix>.png` exists;
+    // returns the owning iconset name, or null. Mirrors MaterialIconType's walk.
+    private static String resolveIconSet(
+            com.gregtechceu.gtceu.api.data.chemical.material.info.MaterialIconSet iconSet,
+            String typeName, String suffix, java.nio.file.Path texDir) {
+        var cur = iconSet;
+        while (cur != null) {
+            if (java.nio.file.Files.exists(texDir.resolve(cur.name).resolve(typeName + suffix + ".png")))
+                return cur.name;
+            if (cur.isRootIconset) break;
+            cur = cur.parentIconset;
+        }
+        return null;
+    }
+}
