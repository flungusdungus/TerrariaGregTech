+        // Upstream's per-(iconType,iconSet) model is a single iconset — its
+        // _secondary / _overlay textures sit in the SAME folder. Resolving each
+        // layer's iconset independently would let an aux layer fall through to
+        // a different parent set (e.g. radioactive/plate_secondary stranded on
+        // a metallic/plate base) — a stray-overlay artifact.
+        String owner = resolveIconSet(iconSet, texName, "", texDir);
