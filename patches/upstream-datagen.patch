+        var iconSet = material.getMaterialIconSet();
+        String rel = category + "/material_sets";
+        java.nio.file.Path texDir = packOutput.getOutputFolder().getParent().getParent()
+                .resolve("main/resources/assets/gtceu/textures/" + rel);
