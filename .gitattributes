# Normalize line endings
* text=auto eol=lf
*.cs text eol=lf
*.csproj text eol=lf
*.json text eol=lf
*.hjson text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Windows-only scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.ogg binary
*.wav binary
*.tmod binary
